{
  "name": "jarvis",
  "version": "0.1.0",
  "description": "Assistente pessoal do Mestre",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node scripts/build-native.js",
    "build": "electron-builder --mac --dir",
    "build:dmg": "electron-builder --mac dmg",
    "postinstall": "node scripts/build-native.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Eduardo Carvalho",
  "license": "ISC",
  "type": "module",
  "private": "true",
  "build": {
    "appId": "com.papoite282.jarvis",
    "productName": "Jarvis",
    "copyright": "Eduardo Carvalho",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false
    },
    "files": [
      "**/*",
      "!.env*",
      "!.DS_Store",
      "!native/*.swift",
      "!**/*.log"
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/claude-code/**",
      "node_modules/@anthropic-ai/claude-agent-sdk/**",
      "native/speech-cli"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "@anthropic-ai/claude-code": "^2.1.195",
    "dotenv": "^17.4.2"
  }
}
